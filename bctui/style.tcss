AlbumList, TrackList {
    height: 1fr;
    border: round $foreground;
    background: $background;
    background-tint: $background;
    scrollbar-size: 1 1;

    &:focus {
        border: round $primary;
    }
}

AlbumList {
    width: 0.33fr;
}

TrackList {
    width: 0.67fr;
}

Bar {
    width: 1.0fr;
}

Footer {
    background: $background;
}
